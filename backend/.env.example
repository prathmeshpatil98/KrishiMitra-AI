# =============================================================================
# KrishiMitra AI — Backend Environment Variables Example
# =============================================================================
# Copy this file to backend/.env and fill in all required values.
# Never commit backend/.env to version control.

# --- Application ---
APP_NAME=KrishiMitra AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=console
TIMEZONE=Asia/Kolkata

# --- FastAPI Server ---
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- PostgreSQL ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=krishimitra
DATABASE_USER=postgres
DATABASE_PASSWORD=your_strong_password_here
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT Authentication (REQUIRED — min 64 random characters each) ---
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING_NEVER_COMMIT_THIS
JWT_REFRESH_SECRET_KEY=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- LangGraph ---
LANGGRAPH_CHECKPOINTER=postgres
LANGGRAPH_THREAD_TIMEOUT=300
LANGGRAPH_MAX_ITERATIONS=15

# --- LangSmith Tracing (optional in development) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=KrishiMitra AI

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=4000

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- AGMARKNET (Market Prices) ---
AGMARKNET_API_KEY=
AGMARKNET_BASE_URL=https://agmarknet.gov.in/api

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_DISTANCE_MATRIX_API_KEY=
GOOGLE_PLACES_API_KEY=

# --- OpenWeather ---
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# --- Government Schemes ---
GOVERNMENT_API_URL=
GOVERNMENT_API_KEY=

# --- Voice AI ---
WHISPER_MODEL=large-v3
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=

# --- SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT=10

# --- Cache TTLs (seconds) ---
CACHE_TTL_MARKET=300
CACHE_TTL_WEATHER=600
CACHE_TTL_SCHEMES=86400

# --- Feature Flags ---
ENABLE_VOICE=true
ENABLE_STREAMING=true
ENABLE_ANALYTICS=false
ENABLE_DEBUG_PANEL=false
ENABLE_SWAGGER=true

# --- Monitoring ---
SENTRY_DSN=
ENABLE_METRICS=true
